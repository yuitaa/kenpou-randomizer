---
import Layout from '@/Layout/Layout.astro';
import ActionButton from '@/components/ActionButton.astro';
import ConstitutionCard from '@/components/ConstitutionCard.astro';
import Header from '@/components/Header.astro';
import { extractedWords, processedConstitution } from '@/data/processedConstitution';

const siteUrl = Astro.url.toString();
---

<Layout description="日本国憲法をランダムに改正します">
  <main class="flex min-h-screen flex-col items-center bg-amber-50 px-4 py-8">
    <div class="flex w-full max-w-3xl flex-col items-center gap-6">
      <Header>日本国憲法ランダマイザー</Header>

      <div class="flex w-full flex-wrap justify-center gap-4">
        <ActionButton id="randomize-btn" variant="primary" class="px-10"> 憲法を改正する </ActionButton>

        <ActionButton id="speak-btn" variant="secondary" class="hidden text-base"> 読み上げる </ActionButton>

        <ActionButton id="copy-btn" variant="secondary" class="text-base"> この条文をコピー </ActionButton>
      </div>

      <ConstitutionCard />

      <p class="text-xs text-amber-700/60 italic">※このアプリはジョークで、実在の法典や政治的意図とは無関係です。</p>
    </div>
  </main>

  <script
    id="app-data"
    type="application/json"
    set:html={JSON.stringify({ processedConstitution, extractedWords, siteUrl })}
  />
  <script src="../scripts/randomizer.ts"></script>
</Layout>
